# みつもるくん — 環境変数テンプレート
# このファイルをコピーして .env を作成してください
# cp .env.example .env
#
# ⚠️ セキュリティ注意事項:
#   - このファイルをそのままコピーせず、必ずパスワードを変更してください
#   - .env ファイルは絶対に git にコミットしないでください
#   - ★マークの項目はデフォルト値なし（必須設定）

# ================================================================
# PostgreSQL
# ================================================================
POSTGRES_DB=mitsumorukun
POSTGRES_USER=postgres
POSTGRES_PASSWORD=                  # ★必須: 強力なパスワードを設定 (例: openssl rand -base64 32)
POSTGRES_PORT=5432                  # 開発用ポート公開（本番では削除推奨）

# ================================================================
# MinIO（ファイルストレージ）
# ================================================================
MINIO_ROOT_USER=                    # ★必須: ユーザー名を設定（minioadmin以外）
MINIO_ROOT_PASSWORD=                # ★必須: 強力なパスワードを設定 (例: openssl rand -base64 32)
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001             # MinIO Web コンソール（本番では削除推奨）
MINIO_BUCKET=mitsumorukun           # アプリが使うバケット名（初回アクセス時に自動作成）

# ================================================================
# OpenAI API（必須）
# ================================================================
OPENAI_API_KEY=                     # ★必須: OpenAI ダッシュボードで取得
OPENAI_MODEL=gpt-5.4-mini           # 主処理 (normal): 要件抽出・FP算出・ドラフト生成。精度重視の差し替え先。
OPENAI_MODEL_LIGHT=gpt-5.4-mini     # 軽量処理 (light): チャンク要約・トピック抽出など量が多い処理。
                                    # MVP は両方同じモデルで出発し、必要箇所だけ後から差し替える方針。

# ================================================================
# アプリケーションポート
# ================================================================
FRONTEND_PORT=3000    # Next.js

# ================================================================
# ログレベル（DEBUG / INFO / WARNING / ERROR）
# ================================================================
LOG_LEVEL=INFO
